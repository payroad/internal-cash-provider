{
    "name": "payroad/internal-cash-provider",
    "description": "Internal (manual) cash payment provider for Payroad",
    "type": "library",
    "require": {
        "php": "^8.2",
        "payroad/payroad-core": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Payroad\\Provider\\InternalCash\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../payroad-core"
        }
    ]
}
